{
  "schema_version": "peer-harness-command-profiles.v2",
  "observed_at": "2026-06-18",
  "profiles": [
    {
      "harness_id": "pi",
      "command": "cerberus-peer-harness",
      "args": [
        "--harness",
        "pi"
      ],
      "timeout_ms": 300000,
      "env_required": [
        "OPENROUTER_API_KEY"
      ],
      "requires_provider_budget_ack": true,
      "output_contract": "reviewer_artifact_file",
      "peer": {
        "command": "pi",
        "args_template": [
          "--print",
          "--no-session",
          "--mode",
          "json",
          "--model",
          "openrouter/{model}",
          "{prompt}"
        ],
        "prompt_mode": "argv_message",
        "notes": "Grounded in `pi --help` on 2026-06-18. The protocol runner must render CommandHarnessInput into {prompt} and parse peer output into ReviewerArtifact.v1."
      },
      "unsupported": [
        "daemonized children outside the process group",
        "unbounded live output files",
        "paid provider calls without an explicit eval budget"
      ],
      "notes": "Pi is the minimal prompt-discipline baseline."
    },
    {
      "harness_id": "goose",
