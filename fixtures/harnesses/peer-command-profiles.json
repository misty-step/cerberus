{
  "schema_version": "peer-harness-command-profiles.v3",
  "observed_at": "2026-06-19",
  "profiles": [
    {
      "harness_id": "pi",
      "command": "cerberus-peer-harness",
      "args": [
        "--harness",
        "pi"
      ],
      "timeout_ms": 300000,
      "env_required": [
        "OPENROUTER_API_KEY"
      ],
      "requires_provider_budget_ack": true,
      "output_contract": "reviewer_artifact_file",
      "peer": {
        "command": "pi",
        "args_template": [
          "--print",
          "--no-session",
          "--mode",
          "json",
          "--model",
          "openrouter/{model}",
          "@{prompt_file}"
        ],
        "prompt_mode": "prompt_file",
        "notes": "Grounded in `pi --help` on 2026-06-19. Pi accepts @files in message arguments; the runner renders the prompt to a private file and passes only @<path>."
      },
      "unsupported": [
        "daemonized children outside the process group",
        "unbounded live output files",
        "paid provider calls without an explicit eval budget"
      ],
      "notes": "Pi is the minimal prompt-discipline baseline."
    },
