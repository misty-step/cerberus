#!/usr/bin/env bash
set -euo pipefail

if [[ "${GH_TOKEN:-}" != "" ]]; then
  echo "GH_TOKEN leaked into fake-opencode" >&2
  exit 64
fi

if [[ "$*" == *"Avoid divide by zero"* ]]; then
  echo "private request material leaked through argv" >&2
  exit 65
fi

script_dir="$(cd "$(dirname "$0")" && pwd)"
repo_root="$(cd "$script_dir/../.." && pwd)"
template="$repo_root/fixtures/harness/valid-review.txt"

original_args="$*"
request_file=""
workdir=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    run)
      shift
      ;;
    --format)
      [[ "${2:-}" == "json" ]] || exit 66
      shift 2
      ;;
    --dir)
      workdir="${2:-}"
      shift 2
      ;;
    --file)
      request_file="${2:-}"
      shift 2
      ;;
    --model|--attach|--agent)
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

test -n "$request_file"
test -s "$request_file"
test -n "$workdir"

request_digest="$(printf '%s\n' "$original_args" | sed -n 's/.*Request digest: \(sha256:[a-f0-9]*\).*/\1/p' | head -1)"
test -n "$request_digest"
request_id="$(sed -n 's/.*"request_id": "\([^"]*\)".*/\1/p' "$request_file" | head -1)"
test -n "$request_id"

if [[ -f "$workdir/request.json" ]]; then
  test -f "$workdir/change.diff"
  test ! -f "$workdir/Cargo.toml"
  capabilities='{"diff":true,"repo_head":false,"repo_base":false,"local_runtime":false,"remote_runtime":false,"external_research":"forbid"}'
else
  test -e "$workdir/.git"
  test -f "$workdir/src/ratio.rs"
  grep -F "\"path\": \"$workdir\"" "$request_file" >/dev/null || {
    echo "request workspace path was not rewritten to the disposable worktree" >&2
    exit 67
  }
  capabilities='{"diff":true,"repo_head":true,"repo_base":false,"local_runtime":false,"remote_runtime":false,"external_research":"forbid"}'
fi

sed \
  -e "s/{{request_id}}/$request_id/g" \
  -e "s#{{request_digest}}#$request_digest#g" \
  -e "s#{{context_capabilities}}#$capabilities#g" \
  -e "s/{{artifact_id}}/artifact-fake-opencode/g" \
  -e "s/{{now}}/0/g" \
  "$template"
