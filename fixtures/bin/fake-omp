#!/usr/bin/env bash
set -euo pipefail

if [[ "${1:-}" == "--version" ]]; then
  echo "omp 17.0.2"
  exit 0
fi

if [[ "${GH_TOKEN:-}" != "" ]]; then
  echo "GH_TOKEN leaked into fake-omp" >&2
  exit 64
fi

if [[ "$*" == *"Avoid divide by zero"* ]]; then
  echo "private request material leaked through argv" >&2
  exit 65
fi

script_dir="$(cd "$(dirname "$0")" && pwd)"
repo_root="$(cd "$script_dir/../.." && pwd)"
template="$repo_root/fixtures/harness/valid-review.txt"

prompt=""
workdir=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --cwd)
      workdir="${2:-}"
      shift 2
      ;;
    @*)
      prompt="${1#@}"
      shift
      ;;
    --model)
      shift 2
      ;;
    *)
      shift
      ;;
  esac
done

test -n "$prompt"
test -s "$prompt"
test -n "$workdir"
test -f "$workdir/request.json"
test -f "$workdir/change.diff"
test ! -f "$workdir/Cargo.toml"

request_digest="$(sed -n 's/^Request digest: //p' "$prompt" | head -1)"
test -n "$request_digest"

capabilities='{"diff":true,"repo_head":false,"repo_base":false,"local_runtime":false,"remote_runtime":false,"external_research":"forbid"}'

# Emit the review by writing the artifact file in the workspace, exactly as the
# prompt now instructs a real agent to. The harness reads it back; nothing on
# stdout is parsed for the artifact.
sed \
  -e "s/{{request_id}}/fixture-diff-only-001/g" \
  -e "s#{{request_digest}}#$request_digest#g" \
  -e "s#{{context_capabilities}}#$capabilities#g" \
  -e "s/{{artifact_id}}/artifact-fake-omp/g" \
  -e "s/{{now}}/0/g" \
  "$template" > "$workdir/review-artifact.json"

printf '%s\n' '{"type":"agent_end","messages":[{"role":"assistant","content":[],"stopReason":"stop"}]}'
